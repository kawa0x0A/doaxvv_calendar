        new Character() { Name = "のぞみ", Birthday = (9, 30), ImageUrl = "https://doax-venusvacation.jp/wp-content/themes/doax-venusvacation/img/character/icon_c3295188.jpg" },
    };

    private readonly string[] DayNames = new[] { "日", "月", "火", "水", "木", "金", "土" };

    [Parameter]
    public DateTime CurrentMonth { get; set; } = DateTime.Today;

    [Parameter]
    public EventCallback<DateTime> CurrentMonthChanged { get; set; }

    private DateTime MonthString
    {
        get => CurrentMonth;
        set
        {
            if (DateTime.TryParse(value + "-01", out var parsed))
            {
                CurrentMonth = parsed;
                CurrentMonthChanged.InvokeAsync(CurrentMonth);
            }
        }
    }

    private Character? nextBirthdayCharacter;
    private DateTime? nextBirthdayDate;

    protected override async Task OnInitializedAsync()
    {
        CalculateNextBirthday();
    }

    private async Task PrevMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        await CurrentMonthChanged.InvokeAsync(CurrentMonth);
    }

    private async Task NextMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(1);
        await CurrentMonthChanged.InvokeAsync(CurrentMonth);
    }

    private Character? GetCharacterForDay(DateTime day)
    {
        return characters?
            .FirstOrDefault(c =>
                c.Birthday != null &&
                c.Birthday.Value.Month == day.Month &&
                c.Birthday.Value.Day == day.Day);
    }

    private IEnumerable<Character> UnknownCharacters =>
        characters?.Where(c => c.Birthday == null)
        ?? Enumerable.Empty<Character>();

    // ===== 7列カレンダー生成ロジック =====
    private List<List<DateTime?>> CalendarWeeks
    {
        get
        {
            var weeks = new List<List<DateTime?>>();
            var firstDay = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);
            var daysInMonth = DateTime.DaysInMonth(CurrentMonth.Year, CurrentMonth.Month);

            var currentWeek = new List<DateTime?>();

            // 月初の空白
            for (int i = 0; i < (int)firstDay.DayOfWeek; i++)
                currentWeek.Add(null);

            // 日付追加
            for (int day = 1; day <= daysInMonth; day++)
            {
                currentWeek.Add(new DateTime(CurrentMonth.Year, CurrentMonth.Month, day));

                if (currentWeek.Count == 7)
                {
                    weeks.Add(currentWeek);
                    currentWeek = new List<DateTime?>();
                }
            }

            // 月末の空白
            if (currentWeek.Count > 0)
            {
                while (currentWeek.Count < 7)
                {
                    currentWeek.Add(null);
                }

                weeks.Add(currentWeek);
            }

            return weeks;
        }
    }

    private void CalculateNextBirthday()
    {
        if (characters == null) return;

        var today = DateTime.Today;

        var result = characters
            .Where(c => c.Birthday != null)
            .Select(c =>
            {
                var nextDate = new DateTime(
                    today.Year,
                    c.Birthday!.Value.Month,
                    c.Birthday.Value.Day);

                if (nextDate < today)
                    nextDate = nextDate.AddYears(1);

                return new
                {
                    Character = c,
                    Date = nextDate
                };
            })
            .OrderBy(x => x.Date)
            .FirstOrDefault();

        if (result != null)
        {
            nextBirthdayCharacter = result.Character;
            nextBirthdayDate = result.Date;
        }
    }
}
