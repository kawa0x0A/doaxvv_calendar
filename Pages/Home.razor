@page "/"


<div class="container py-4">

    <h2 class="mb-4 text-center">DOA XVV キャラクター誕生日カレンダー</h2>

    <!-- 今日の日付表示 -->
    <div class="mb-3 text-center">
        <div class="fs-5 fw-bold">
            今日：@DateTime.Today.ToString("yyyy年M月d日")
        </div>
    </div>

    @if (nextBirthdayCharacter != null && nextBirthdayDate != null)
    {
        var daysLeft = (nextBirthdayDate.Value - DateTime.Today).Days;

        <div class="alert alert-info mb-4 text-center">

            <img src="@nextBirthdayCharacter.ImageUrl" class="rounded-circle me-2 border" style="width:50px;height:50px;object-fit:cover" />

            @if (daysLeft == 0)
            {
                <span class="text-success fw-bold">本日は @nextBirthdayCharacter のお誕生日です！🎉</span>
            }
            else
            {
                <strong>
                    @nextBirthdayCharacter.Name のお誕生日まで @daysLeft 日 ( @nextBirthdayDate.Value.ToString("M月d日") )
                </strong>
            }

        </div>
    }

    <!-- 月移動 -->
    <div class="d-flex justify-content-center align-items-center mb-3 gap-3">
        <button class="btn btn-outline-secondary btn-sm" @onclick="PrevMonth">
            ‹
        </button>

        <input type="month" class="form-control form-control-sm w-auto" @bind="MonthString" @bind:event="onchange" />

        <button class="btn btn-outline-secondary btn-sm" @onclick="NextMonth">
            ›
        </button>
    </div>

    @if (characters == null)
    {
        <div class="text-center">Loading...</div>
    }
    else
    {
        <!-- 曜日ヘッダー -->
        <div class="row fw-bold border-bottom mb-2 pb-2 text-center">
            @for (int i = 0; i < DayNames.Length; i++)
            {
                <div class="col
                    @(i == 0 ? "text-danger" : "")
                    @(i == 6 ? "text-primary" : "")">
                    @DayNames[i]
                </div>
            }
        </div>

        <!-- カレンダー本体 -->
        @foreach (var week in CalendarWeeks)
        {
            <div class="row g-2 mb-2">
                @for (int i = 0; i < 7; i++)
                {
                    var day = week[i];
    
                    if (day == null)
                    {
                        <div class="col">
                            <div style="height:100px;"></div>
                        </div>
                    }
                    else
                    {
                        var character = GetCharacterForDay(day.Value);
                        var isToday = day.Value.Date == DateTime.Today;

                        <div class="col">
                            <div class="d-flex flex-column rounded border p-2 text-center
                        @(isToday ? "bg-light" : "")"
                                 style="min-height:130px">

                                <!-- 日付 -->
                                <div class="small fw-bold
                            @(i == 0 ? "text-danger" : "")
                            @(i == 6 ? "text-primary" : "")">
                                    @day.Value.Day
                                </div>

                                <!-- 中央スペース -->
                                <div class="flex-grow-1 d-flex flex-column
                                    justify-content-center align-items-center">

                                    @if (character != null)
                                    {
                                        <img src="@character.ImageUrl"
                                             class="rounded-circle mb-1 border"
                                             style="width:40px;height:40px;object-fit:cover" />

                                        <div class="small text-success fw-semibold px-1">
                                            @($"{character.Name}のお誕生日")
                                        </div>
                                    }
                                </div>

                                <!-- 下余白確保 -->
                                <div style="height:6px;"></div>

                            </div>
                        </div>
                    }
                }
            </div>
        }

        <!-- 誕生日不明 -->
        <h5 class="mt-5">誕生日不明</h5>

        <div class="d-flex flex-wrap gap-3">
            @foreach (var c in UnknownCharacters)
            {
                <div class="text-center">
                    <img src="@c.ImageUrl"
                         class="rounded-circle border"
                         style="width:56px;height:56px;object-fit:cover"
                         title="@c.Name" />
                    <div class="small mt-1">@c.Name</div>
                </div>
            }
        </div>
    }
</div>
